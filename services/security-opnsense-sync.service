[Unit]
Description=security-core OPNsense sync worker
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=securitycore
Group=securitycore
WorkingDirectory=/opt/security-core/app
EnvironmentFile=/etc/security-core/security-core.env
Environment=PYTHONPATH=/opt/security-core/app
ExecStart=/opt/security-core/venv/bin/python /opt/security-core/app/worker/sync_opnsense.py
